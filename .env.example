# ============================================================
# Short Interest Squeeze Dashboard - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Defaults below work out-of-the-box with SQLite + mock data.

# --------------- Database ---------------
# SQLite (dev default - no setup needed)
DATABASE_URL=sqlite:///./squeeze.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://squeeze_user:squeeze_pass@localhost:5432/squeeze_db

# --------------- Data Provider ---------------
# Options: mock | ortex | fintel
DATA_PROVIDER=mock

# Ortex API (if DATA_PROVIDER=ortex)
# ORTEX_API_KEY=your_ortex_api_key
# ORTEX_BASE_URL=https://api.ortex.com/v1

# Fintel API (if DATA_PROVIDER=fintel)
# FINTEL_API_KEY=your_fintel_api_key
# FINTEL_BASE_URL=https://api.fintel.io/v1

# --------------- Auth ---------------
JWT_SECRET=changeme-use-a-strong-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Default admin user (created on first seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# --------------- CORS ---------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --------------- Redis (optional) ---------------
# REDIS_URL=redis://localhost:6379/0

# --------------- FINRA Data ---------------
# Local directory for downloaded FINRA short interest CSVs
FINRA_DATA_DIR=./data/finra

# --------------- Scheduler ---------------
# How often ETL jobs run (hours)
SCHEDULER_INTERVAL_HOURS=6

# --------------- Notifications ---------------
# SMTP for email alerts
# ALERT_EMAIL_SMTP=smtp.gmail.com
# ALERT_EMAIL_PORT=587
# ALERT_EMAIL_USER=alerts@example.com
# ALERT_EMAIL_PASSWORD=your_email_password
# ALERT_EMAIL_FROM=alerts@example.com

# --------------- App ---------------
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
